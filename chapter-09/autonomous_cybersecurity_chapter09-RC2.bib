@InProceedings{Gimenez2025,
  author       = {Gimenez, Pierre-François},
  booktitle    = {ANUBIS 2025 - 1st International Workshop on Assessment with New methodologies},
  title        = {Synthetic network traffic generation for intrusion detection systems: a systematic literature review},
  doi          = {https://doi.org/10.34894/VQ1DJA},
  organization = {ANUBIS 2025 - 1st International Workshop on Assessment with New methodologies},
  pages        = {1–18},
  publisher    = {Université de Limoges},
  url          = {https://hal.science/hal-05379236 https://hal.science/hal-05379236/document},
  abstract     = {Network data can be difficult to collect due to privacy and confidentiality reasons. For these reasons, network datasets are typically created with controlled environments called testbeds. However, these datasets are regularly criticized for their limited size, class imbalance, obsolescence, and lack of actual user activity. Following the rapid development of generative artificial intelligence, new methods have been applied to synthetic network traffic generation without emulation or simulation. This systematic literature review assesses the current state of synthetic network traffic generation for intrusion detection systems.},
  issue        = {1},
  keywords     = {Generative AI,Networking,Networking Generative AI Traffic Generation,Photovoltaïques Organiques (OPVs),Simultaneous Lightwave Information and Power Trans,Traffic Generation,Transfert Simultané d’Information et d’Énergie par,Visible Light Communication (VLC)},
  month        = sep,
  school       = {Université de Limoges},
  year         = {2025},
}

@InProceedings{Steinel2025,
  author       = {Steinel, Ricky B. and Lim, Kiho and Ku, Cyril S.},
  booktitle    = {2025 International Conference On Convergent And Smart Systems (ICCSS 2025)},
  title        = {Synthetic data generation for cybersecurity applications: an exploratory study of gan models},
  organization = {2025 INTERNATIONAL CONFERENCE ON CONVERGENT AND SMART SYSTEMS (ICCSS 2025)},
  publisher    = {PIONEER INTERNATIONAL UNIVERSITY, Pioneer International University, Nairobi, KENYANAIROBI, K. E. N. Y. A.},
  url          = {https://www.wpunj.edu/cosh/macs-scholars-program/assets/SyntheticData.pdf},
  abstract     = {1 Cyeersecurity systems rely heavily on high-quality datasets to train effective intrusion detection mechanisms and malware classification models. However, real-world cybersecurity datasets often face challenges such as limited availability, high annotation costs, privacy risks, and imbalanced class distributions. Generative Adversarial Networks (GANs) have emerged as a promising approach for generating synthetic data that mimics real datasets' statistical properties and structural patterns while preserving privacy. This paper explores multiple GAN variants: CGAN, CycleGAN, BiGAN, DGAN, LSGAN, Tabular GANs, WGAN, WGAN-GP, SeqGAN, and TextGAN, in the context of cybersecurity. Two case studies are conducted: the use of SeqGAN to generate synthetic network traffic based on the NSL-KDD dataset, and the application of TextGAN to produce realistic malicious PHP code snippets. Each model is evaluated for data fidelity, structural validity, and utility in downstream machine learning tasks. The results demonstrate the potential of GANs to enhance data-driven cybersecurity research and operations by simulating attack scenarios and augmenting limited datasets. Future directions include exploring hybrid models, integrating real-time synthesis, and aligning synthetic data generation with evolving threat intelligence paradigms.},
  keywords     = {GAN,SeqGAN,TextGAN,cyeersecurity,generative adversarial networks,intrusion detection,synthetic data},
  month        = jun,
  year         = {2025},
}

@TechReport{Cate2024,
  author   = {Cate, Mia and Sai', Zaynab},
  title    = {Synthetic data generation for training ai models in web security contexts},
  url      = {https://www.researchgate.net/publication/392518778_Synthetic_Data_Generation_for_Training_AI_Models_in_Web_Security_Contexts},
  abstract = {The increasing complexity and frequency of cyber-attacks necessitate advanced threat detection systems capable of identifying novel and sophisticated intrusions. However, the scarcity of labeled attack data poses significant challenges for training robust AI models in web security contexts. This study explores the generation of realistic synthetic data representing diverse cyber-attack scenarios to augment existing datasets for training AI-driven threat detection systems. Leveraging generative models and domain-specific knowledge, the synthetic data aims to emulate the statistical and behavioral characteristics of real-world attacks while preserving data diversity and complexity. The research evaluates the effectiveness of synthetic attack scenarios in improving model generalization, detection accuracy, and resilience against emerging threats. Results demonstrate that incorporating synthetic data significantly enhances AI models' ability to detect previously unseen attack patterns, thereby strengthening web security defenses. This approach presents a promising avenue for overcoming data limitations and advancing proactive cybersecurity measures.},
  keywords = {AI Training Data,Anomaly Detection,Artificial Intelligence,Cyber-Attack Simulation,Cybersecurity,Data Augmentation,Generative Models,Intrusion Detection Systems,Machine Learning,Synthetic Data Generation,Threat Detection,Web Security},
  year     = {2024},
}

